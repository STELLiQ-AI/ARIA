<?xml version="1.0" encoding="utf-8"?>
<!-- Large record button — gold circle with subtle glow ring -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring -->
    <item
        android:bottom="2dp"
        android:left="2dp"
        android:right="2dp"
        android:top="2dp">
        <shape android:shape="oval">
            <solid android:color="#18F0A030" />
        </shape>
    </item>
    <!-- Inner solid circle -->
    <item
        android:bottom="6dp"
        android:left="6dp"
        android:right="6dp"
        android:top="6dp">
        <shape android:shape="oval">
            <solid android:color="#F0A030" />
        </shape>
    </item>
</layer-list>
