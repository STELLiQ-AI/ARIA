<?xml version="1.0" encoding="utf-8"?>
<!--
    splash_icon_transparent.xml

    Purpose: Transparent/empty drawable for Android 12+ system splash screen.
             This ensures the system splash shows only the background color,
             making it invisible before our custom splash activity appears.

    Product: ARIA - AI-Powered Recording & Intelligent Analysis
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@android:color/transparent" />
    <size
        android:width="1dp"
        android:height="1dp" />
</shape>
