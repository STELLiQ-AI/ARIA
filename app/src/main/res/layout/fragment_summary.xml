<?xml version="1.0" encoding="utf-8"?>
<!--
  fragment_summary.xml

  Purpose: Completed summary display — four-step format
           with card-based sections and action buttons.

  Product: ARIA - AI-Powered Recording & Intelligent Analysis
  Author:  STELLiQ Engineering
  Version: 5.0.0
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="100dp">

        <!-- Header with accent bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="3dp"
                android:layout_height="22dp"
                android:background="@color/primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@null"
                android:fontFamily="sans-serif-medium"
                android:text="@string/summary_title"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:letterSpacing="-0.01" />
        </LinearLayout>

        <!-- Section 1: What Was Planned -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/surface_container"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:text="@string/aar_what_planned"
                    android:textAllCaps="true"
                    android:textColor="@color/primary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/text_what_planned"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="The objective was to conduct a squad-level patrol..." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section 2: What Happened -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface_container"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:text="@string/aar_what_happened"
                    android:textAllCaps="true"
                    android:textColor="@color/primary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/text_what_happened"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="The patrol encountered unexpected terrain..." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section 3: Why It Happened -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface_container"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:text="@string/aar_why_happened"
                    android:textAllCaps="true"
                    android:textColor="@color/primary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/text_why_happened"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="The map was outdated and did not reflect..." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Section 4: How to Improve -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/surface_container"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/card_border"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.06"
                    android:text="@string/aar_how_improve"
                    android:textAllCaps="true"
                    android:textColor="@color/primary"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/text_how_improve"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:lineSpacingMultiplier="1.6"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    tools:text="1. Verify maps with recent satellite imagery..." />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Performance Metrics -->
        <TextView
            android:id="@+id/text_metrics"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:background="@null"
            android:fontFamily="monospace"
            android:textColor="@color/text_tertiary"
            android:textSize="12sp"
            tools:text="TTFT: 1.8s | Decode: 24.5 tok/s" />

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="28dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_share"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/button_share"
                android:textColor="@color/on_primary"
                android:textSize="15sp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_share"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:iconTint="@color/on_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_new_session"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/button_new_session"
                android:textColor="@color/primary"
                android:textSize="15sp"
                app:cornerRadius="12dp"
                app:strokeColor="@color/outline"
                app:strokeWidth="0dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
