<?xml version="1.0" encoding="utf-8"?>
<!--
  themes.xml

  Purpose: Theme definitions for ARIA commercial app.
           Deep purple + luminous gold — premium and refined.

  Product: ARIA - AI-Powered Recording & Intelligent Analysis
  Author:  STELLiQ Engineering
  Version: 5.0.0
-->
<resources>

    <!-- ===================================================================== -->
    <!-- Base Application Theme — Deep Purple + Gold                           -->
    <!-- ===================================================================== -->

    <style name="Theme.ARIA" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary colors — Gold -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/on_primary_container</item>

        <!-- Secondary colors — Amber -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/on_secondary_container</item>

        <!-- Tertiary colors — Peach -->
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorTertiaryContainer">@color/tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/on_tertiary_container</item>

        <!-- Surface colors — Deep Purple -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Background — Near-Black Purple -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorOnBackground">@color/on_background</item>

        <!-- Error colors -->
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="colorErrorContainer">@color/error_container</item>
        <item name="colorOnErrorContainer">@color/on_error_container</item>

        <!-- Outline -->
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <!-- Status bar — Transparent for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar — Blends with bottom nav -->
        <item name="android:navigationBarColor">@color/nav_bar_bg</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/background</item>

        <!-- Interaction overlays -->
        <item name="android:textColorHighlight">@android:color/transparent</item>
        <item name="android:colorControlHighlight">@color/ripple</item>

        <!-- Component styles -->
        <item name="materialButtonStyle">@style/Widget.ARIA.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.ARIA.Button.Outlined</item>
        <item name="materialCardViewStyle">@style/Widget.ARIA.CardView</item>
        <item name="textInputStyle">@style/Widget.ARIA.TextInputLayout</item>
    </style>

    <!-- ===================================================================== -->
    <!-- Splash Screen Theme                                                   -->
    <!-- ===================================================================== -->

    <style name="Theme.ARIA.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/background</item>
        <item name="postSplashScreenTheme">@style/Theme.ARIA.SplashActivity</item>
    </style>

    <style name="Theme.ARIA.SplashActivity" parent="Theme.ARIA">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
    </style>

    <!-- ===================================================================== -->
    <!-- Button Styles — Refined with Rounded Corners                          -->
    <!-- ===================================================================== -->

    <!-- Primary filled button — gold with dark text, no visible border -->
    <style name="Widget.ARIA.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/btn_primary_text</item>
        <item name="backgroundTint">@color/btn_primary_bg</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Outlined button — hairline border -->
    <style name="Widget.ARIA.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/btn_outlined_text</item>
        <item name="strokeColor">@color/btn_outlined_stroke</item>
        <item name="strokeWidth">0.5dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Text button -->
    <style name="Widget.ARIA.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- FAB style -->
    <style name="Widget.ARIA.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/on_primary</item>
    </style>

    <!-- Recording FAB -->
    <style name="Widget.ARIA.FloatingActionButton.Recording" parent="Widget.Material3.FloatingActionButton.Large.Primary">
        <item name="backgroundTint">@color/recording_red</item>
        <item name="tint">@color/text_primary</item>
    </style>

    <!-- ===================================================================== -->
    <!-- Card Styles — Premium Panels with Subtle Glow                         -->
    <!-- ===================================================================== -->

    <style name="Widget.ARIA.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/surface_container</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="contentPadding">16dp</item>
        <item name="strokeColor">@color/card_border</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.ARIA.CardView.Elevated" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_container_high</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_border</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- ===================================================================== -->
    <!-- Text Input Styles                                                     -->
    <!-- ===================================================================== -->

    <style name="Widget.ARIA.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface_container</item>
        <item name="boxStrokeColor">@color/outline</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_tertiary</item>
    </style>

    <!-- ===================================================================== -->
    <!-- Text Appearance — Refined Typography                                  -->
    <!-- ===================================================================== -->

    <style name="TextAppearance.ARIA.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.ARIA.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">-0.01</item>
    </style>

    <style name="TextAppearance.ARIA.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.ARIA.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ARIA.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.ARIA.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.ARIA.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.ARIA.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Timer display — large monospace gold -->
    <style name="TextAppearance.ARIA.Timer" parent="TextAppearance.Material3.DisplayLarge">
        <item name="android:textColor">@color/primary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <!-- ===================================================================== -->
    <!-- Section Label Style                                                   -->
    <!-- ===================================================================== -->

    <style name="TextAppearance.ARIA.SectionLabel" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- ===================================================================== -->
    <!-- Bottom Navigation                                                     -->
    <!-- ===================================================================== -->

    <style name="Widget.ARIA.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/nav_bar_bg</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.ARIA.BottomNavigationView.ActiveIndicator</item>
    </style>

    <style name="Widget.ARIA.BottomNavigationView.ActiveIndicator" parent="">
        <item name="android:color">@color/nav_indicator</item>
    </style>

    <!-- ===================================================================== -->
    <!-- Chip Styles                                                           -->
    <!-- ===================================================================== -->

    <style name="Widget.ARIA.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/surface_container_high</item>
        <item name="chipStrokeColor">@color/outline_variant</item>
        <item name="chipCornerRadius">8dp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- ===================================================================== -->
    <!-- Progress Indicator                                                    -->
    <!-- ===================================================================== -->

    <style name="Widget.ARIA.LinearProgressIndicator" parent="Widget.Material3.LinearProgressIndicator">
        <item name="indicatorColor">@color/primary</item>
        <item name="trackColor">@color/surface_container_high</item>
        <item name="trackCornerRadius">2dp</item>
    </style>

    <style name="Widget.ARIA.CircularProgressIndicator" parent="Widget.Material3.CircularProgressIndicator">
        <item name="indicatorColor">@color/primary</item>
        <item name="trackColor">@color/surface_container_high</item>
    </style>

</resources>
